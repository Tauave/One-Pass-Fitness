@model IEnumerable<One_Pass_Fitness.Models.Trainers>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Trainedfield)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Datehired)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Person)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Trainedfield)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Datehired)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Person.Email)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Trainersid">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Trainersid">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Trainersid">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
